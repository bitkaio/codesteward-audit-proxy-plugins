{
  "name": "codesteward-audit-proxy",
  "displayName": "Codesteward Audit Proxy",
  "description": "Configure the Codesteward audit proxy, inject identity metadata, and provide observability into what headers are being forwarded to AI coding agents.",
  "version": "1.0.0",
  "publisher": "bitkaio",
  "license": "MIT",
  "icon": "assets/codesteward-icon.png",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Codesteward Audit Proxy",
      "properties": {
        "codesteward.proxy.url": {
          "type": "string",
          "default": "http://localhost:8080",
          "description": "URL of the Codesteward audit proxy"
        },
        "codesteward.proxy.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable or disable the audit proxy"
        },
        "codesteward.identity.user": {
          "type": "string",
          "default": "",
          "description": "User identity override (empty = auto-detect from git)"
        },
        "codesteward.identity.project": {
          "type": "string",
          "default": "",
          "description": "Project name override (empty = auto-detect from workspace)"
        },
        "codesteward.identity.branch": {
          "type": "string",
          "default": "",
          "description": "Branch name override (empty = auto-detect from git)"
        },
        "codesteward.identity.team": {
          "type": "string",
          "default": "",
          "description": "Team or organization identifier"
        },
        "codesteward.headers": {
          "type": "object",
          "default": {},
          "description": "Additional custom headers to inject (key-value pairs)"
        },
        "codesteward.agents.claude": {
          "type": "boolean",
          "default": true,
          "description": "Configure Claude Code CLI and VSCode extension"
        },
        "codesteward.agents.codex": {
          "type": "boolean",
          "default": true,
          "description": "Configure Codex CLI"
        },
        "codesteward.agents.gemini": {
          "type": "boolean",
          "default": true,
          "description": "Configure Gemini CLI"
        },
        "codesteward.agents.cline": {
          "type": "boolean",
          "default": true,
          "description": "Configure Cline extension"
        },
        "codesteward.agents.aider": {
          "type": "boolean",
          "default": true,
          "description": "Configure Aider"
        },
        "codesteward.agents.continue": {
          "type": "boolean",
          "default": true,
          "description": "Configure Continue extension"
        },
        "codesteward.healthCheck.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable periodic proxy health checks"
        },
        "codesteward.healthCheck.intervalSeconds": {
          "type": "number",
          "default": 30,
          "minimum": 5,
          "description": "Health check interval in seconds"
        }
      }
    },
    "commands": [
      {
        "command": "codesteward.toggle",
        "title": "Toggle Proxy",
        "category": "Codesteward",
        "icon": "$(plug)"
      },
      {
        "command": "codesteward.openSettings",
        "title": "Open Settings",
        "category": "Codesteward",
        "icon": "$(gear)"
      },
      {
        "command": "codesteward.showHeaders",
        "title": "Show Header Inspector",
        "category": "Codesteward",
        "icon": "$(list-tree)"
      },
      {
        "command": "codesteward.copySessionId",
        "title": "Copy Session ID",
        "category": "Codesteward",
        "icon": "$(key)"
      },
      {
        "command": "codesteward.refreshIdentity",
        "title": "Refresh Identity",
        "category": "Codesteward",
        "icon": "$(refresh)"
      },
      {
        "command": "codesteward.checkHealth",
        "title": "Check Proxy Health",
        "category": "Codesteward",
        "icon": "$(pulse)"
      },
      {
        "command": "codesteward.copyValue",
        "title": "Copy Value",
        "category": "Codesteward",
        "icon": "$(clippy)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "codesteward.refreshIdentity",
          "when": "view == codesteward.headerInspector",
          "group": "navigation"
        },
        {
          "command": "codesteward.checkHealth",
          "when": "view == codesteward.headerInspector",
          "group": "navigation"
        },
        {
          "command": "codesteward.openSettings",
          "when": "view == codesteward.headerInspector"
        },
        {
          "command": "codesteward.toggle",
          "when": "view == codesteward.headerInspector"
        },
        {
          "command": "codesteward.copySessionId",
          "when": "view == codesteward.headerInspector"
        }
      ],
      "view/item/context": [
        {
          "command": "codesteward.copyValue",
          "when": "view == codesteward.headerInspector && viewItem == copyable",
          "group": "inline"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codesteward",
          "title": "Codesteward",
          "icon": "assets/codesteward-icon-abstract.png"
        }
      ]
    },
    "views": {
      "codesteward": [
        {
          "id": "codesteward.headerInspector",
          "name": "Header Inspector"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "codesteward.headerInspector",
        "contents": "Codesteward audit proxy is not configured yet.\n\nRoute your AI coding agents through the proxy to capture structured audit events with identity metadata.\n\n[Configure Proxy](command:codesteward.toggle)\n\nOr add a `.codesteward.json` to your repo root.\n\n[Open Settings](command:codesteward.openSettings)",
        "when": "!codesteward.configured"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.95.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0",
    "@vscode/vsce": "^3.0.0"
  }
}
